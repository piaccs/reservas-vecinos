# ============================================================
# VARIABLES DE ENTORNO — Gimnasio Collico
# ============================================================
# Copia este archivo como .env.local y rellena con tus valores reales.
# NUNCA subas .env.local a GitHub.
# ============================================================

# --- Supabase ---
# Encuéntralas en: supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXX

# --- Correo (Gmail) ---
# Usa una App Password, no tu contraseña normal de Gmail.
# Cómo crearla: myaccount.google.com → Seguridad → Verificación en 2 pasos → Contraseñas de aplicación
GMAIL_USER=tu-correo@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Correo donde llegan las notificaciones de nuevas reservas (puede ser el mismo)
ADMIN_EMAIL=junta.vecinos.collico@gmail.com

# --- JWT ---
# Genera una frase larga y aleatoria. Ejemplo: una oración inventada + números.
# NUNCA compartas este valor. Si se filtra, regenera uno nuevo y haz redeploy.
JWT_SECRET=escribe-aqui-una-frase-larga-y-secreta-nadie-debe-saber-esto-2026

# --- URL del sitio ---
# En Vercel, esto lo obtienes después del primer deploy.
# Ejemplo: https://reservas-vecinos.vercel.app
NEXT_PUBLIC_BASE_URL=https://tu-sitio.vercel.app

# --- Contraseña inicial de admins (solo para migración) ---
# Una vez que los 3 admins cambien su contraseña desde el panel,
# puedes eliminar esta variable. Después del primer login se hashea automáticamente.
ADMIN_PASSWORD=tu-contrasena-inicial-aqui
